# ---------------------------------------------------------------
# Nuwa Environment Variables
# Copy this file to .env and fill in the values.
# ---------------------------------------------------------------

# -- LLM Provider ------------------------------------------------
# API key for the LLM provider (at least one required).
# LiteLLM auto-detects from standard env vars if not set here.
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=sk-...
# AZURE_API_KEY=...

# -- Web Server --------------------------------------------------
# API key required for all /api/* requests (leave empty to disable auth)
NUWA_API_KEY=

# Allowed CORS origins, comma-separated (default: http://localhost:8080)
# Set to "*" only for local development
NUWA_CORS_ORIGINS=http://localhost:8080

# -- Training Defaults -------------------------------------------
# These can be overridden per-run via the SDK/CLI or config.yaml.
# NUWA_LLM_MODEL=openai/gpt-4o
# NUWA_MAX_ROUNDS=10
# NUWA_TRAIN_VAL_SPLIT=0.7
